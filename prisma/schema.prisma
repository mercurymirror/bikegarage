generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  bikes     Bike[]
}

model Bike {
  id         String      @id @default(uuid())
  name       String
  type       BikeType        @default(ROAD)
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  components Component[]
  rides      Ride[]
}

model ComponentType {
  id           String      @id @default(uuid())
  name         String      @unique
  wearLimitKm  Int
  components   Component[]
}

model Component {
  id              String        @id @default(uuid())
  bikeId          String
  bike            Bike          @relation(fields: [bikeId], references: [id])
  brand           String        @default("noName")
  model           String        @default("noModel")
  componentTypeId String
  componentType   ComponentType @relation(fields: [componentTypeId], references: [id])
  installedAt     DateTime      @default(now())
  replacedAt      DateTime?
}

model Ride {
  id         String   @id @default(uuid())
  bikeId     String
  bike       Bike     @relation(fields: [bikeId], references: [id])
  distanceKm Int
  date       DateTime @default(now())
}

enum BikeType {
  ROAD
  MOUNTAIN
  GRAVEL
  ELECTRIC
  CITY
}